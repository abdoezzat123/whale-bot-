# === إعدادات Solana ===
# فترة فحص محافظ Solana (5 ثواني = شبه real-time)
POLL_SECONDS=5

# === إعدادات BSC ===
# فترة فحص محافظ BSC (BSC أبطأ من Solana، يفضل 10 ثواني)
