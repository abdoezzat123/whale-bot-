# ============================================
# إعدادات البوت - انسخ الملف ده لـ .env واملأ القيم
# ============================================

# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=ضع_التوكن_هنا

# chat ID اللي هتوصله الإشعارات (ابدأ محادثة مع البوت وبعت /start ثم استخدم @userinfobot عشان تجيب الـ ID)
TELEGRAM_CHAT_ID=ضع_الـ_chat_id_هنا

# مفتاح Helius API - سجل من https://www.helius.dev/ (مجاني 100K ريكوست شهرياً)
HELIUS_API_KEY=ضع_مفتاح_helius_هنا

# الحد الأدنى لقيمة المعاملة لإرسال إشعار فوري (بالدولار)
MIN_TX_VALUE_USD=1000

# عدد الحيتان المطلوبين لاعتبار العملة "متجمعة" (3 حيتان في 6 ساعات = إشعار تجميع)
WHALE_ACCUMULATION_THRESHOLD=3
WHALE_ACCUMULATION_WINDOW_HOURS=6

# مدة العملة لاعتبارها "دخول مبكر" (ساعات)
EARLY_ENTRY_HOURS=24

# فترة الملخص الدوري (ساعات)
SUMMARY_INTERVAL_HOURS=6

# فترة فحص المحافظ (ثواني) - 30 ثانية افتراضياً
POLL_INTERVAL_SECONDS=30
